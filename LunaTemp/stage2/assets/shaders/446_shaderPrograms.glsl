["\n#version 300 es\n\n#define HLSLCC_ENABLE_UNIFORM_BUFFERS 0\n#if HLSLCC_ENABLE_UNIFORM_BUFFERS\n#define UNITY_UNIFORM\n#else\n#define UNITY_UNIFORM uniform\n#endif\n#define UNITY_SUPPORTS_UNIFORM_LOCATION 0\n#if UNITY_SUPPORTS_UNIFORM_LOCATION\n#define UNITY_LOCATION(x) layout(location = x)\n#define UNITY_BINDING(x) layout(binding = x, std140)\n#else\n#define UNITY_LOCATION(x)\n#define UNITY_BINDING(x) layout(std140)\n#endif\nuniform \tvec4 hlslcc_mtx4x4unity_ObjectToWorld[4];\nuniform \tvec4 hlslcc_mtx4x4unity_MatrixVP[4];\nuniform \tmediump vec4 _Color;\nin highp vec4 in_POSITION0;\nin highp vec4 in_COLOR0;\nout highp vec4 vs_TEXCOORD0;\nout mediump vec4 vs_COLOR0;\nvec4 u_xlat0;\nvec4 u_xlat1;\nvoid main()\n{\n    u_xlat0 = in_POSITION0.yyyy * hlslcc_mtx4x4unity_ObjectToWorld[1];\n    u_xlat0 = hlslcc_mtx4x4unity_ObjectToWorld[0] * in_POSITION0.xxxx + u_xlat0;\n    u_xlat0 = hlslcc_mtx4x4unity_ObjectToWorld[2] * in_POSITION0.zzzz + u_xlat0;\n    u_xlat0 = u_xlat0 + hlslcc_mtx4x4unity_ObjectToWorld[3];\n    u_xlat1 = u_xlat0.yyyy * hlslcc_mtx4x4unity_MatrixVP[1];\n    u_xlat1 = hlslcc_mtx4x4unity_MatrixVP[0] * u_xlat0.xxxx + u_xlat1;\n    u_xlat1 = hlslcc_mtx4x4unity_MatrixVP[2] * u_xlat0.zzzz + u_xlat1;\n    u_xlat0 = hlslcc_mtx4x4unity_MatrixVP[3] * u_xlat0.wwww + u_xlat1;\n    gl_Position = u_xlat0;\n    u_xlat1.xyz = u_xlat0.xyw * vec3(0.5, 0.5, 0.5);\n    vs_TEXCOORD0.zw = u_xlat0.zw;\n    vs_TEXCOORD0.xy = u_xlat1.zz + u_xlat1.xy;\n    u_xlat0 = in_COLOR0 * _Color;\n    vs_COLOR0 = u_xlat0;\n    return;\n}\n\n","\n#version 300 es\n#ifdef GL_EXT_shader_texture_lod\n#extension GL_EXT_shader_texture_lod : enable\n#endif\n\nprecision highp float;\nprecision highp int;\n#define HLSLCC_ENABLE_UNIFORM_BUFFERS 0\n#if HLSLCC_ENABLE_UNIFORM_BUFFERS\n#define UNITY_UNIFORM\n#else\n#define UNITY_UNIFORM uniform\n#endif\n#define UNITY_SUPPORTS_UNIFORM_LOCATION 0\n#if UNITY_SUPPORTS_UNIFORM_LOCATION\n#define UNITY_LOCATION(x) layout(location = x)\n#define UNITY_BINDING(x) layout(binding = x, std140)\n#else\n#define UNITY_LOCATION(x)\n#define UNITY_BINDING(x) layout(std140)\n#endif\nuniform \tvec4 _GrabTexture_TexelSize;\nuniform \tfloat _Size;\nuniform \tfloat _Passes;\nUNITY_LOCATION(0) uniform mediump sampler2D _GrabTexture;\nin highp vec4 vs_TEXCOORD0;\nin mediump vec4 vs_COLOR0;\nlayout(location = 0) out mediump vec4 SV_Target0;\nvec4 u_xlat0;\nint u_xlati1;\nmediump vec4 u_xlat16_2;\nint u_xlati3;\nvec2 u_xlat4;\nvec4 u_xlat5;\nmediump vec4 u_xlat16_5;\nmediump vec4 u_xlat16_6;\nfloat u_xlat8;\nfloat u_xlat10;\nbool u_xlatb10;\nvec2 u_xlat11;\nvec2 u_xlat14;\nint u_xlati15;\nint u_xlati17;\nfloat u_xlat22;\nfloat u_xlat24;\nint u_xlati24;\nbool u_xlatb24;\nvoid main()\n{\n    u_xlat0.xy = vs_TEXCOORD0.xy / vs_TEXCOORD0.ww;\n    u_xlat14.xy = _GrabTexture_TexelSize.xy * vec2(_Size);\n    u_xlati1 = int(_Passes);\n    u_xlati1 = max(u_xlati1, 1);\n    u_xlat8 = float(u_xlati1);\n    u_xlat8 = u_xlat8 * u_xlat8;\n    u_xlat8 = u_xlat8 * 0.5;\n    u_xlati15 = 0 - u_xlati1;\n    u_xlat16_2.x = float(0.0);\n    u_xlat16_2.y = float(0.0);\n    u_xlat16_2.z = float(0.0);\n    u_xlat16_2.w = float(0.0);\n    u_xlat22 = 0.0;\n    for(int u_xlati_loop_1 = u_xlati15 ; u_xlati1>=u_xlati_loop_1 ; u_xlati_loop_1++)\n    {\n        u_xlat4.x = float(u_xlati_loop_1);\n        u_xlat16_5 = u_xlat16_2;\n        u_xlat10 = u_xlat22;\n        u_xlati17 = u_xlati15;\n        while(true){\n            u_xlatb24 = u_xlati1<u_xlati17;\n            if(u_xlatb24){break;}\n            u_xlati24 = u_xlati17 * (-u_xlati17);\n            u_xlati24 = (-u_xlati_loop_1) * u_xlati_loop_1 + u_xlati24;\n            u_xlat24 = float(u_xlati24);\n            u_xlat24 = u_xlat24 / u_xlat8;\n            u_xlat24 = u_xlat24 * 1.44269502;\n            u_xlat24 = exp2(u_xlat24);\n            u_xlat4.y = float(u_xlati17);\n            u_xlat11.xy = u_xlat4.xy * u_xlat14.xy + u_xlat0.xy;\n            u_xlat16_6 = textureLod(_GrabTexture, u_xlat11.xy, 0.0);\n            u